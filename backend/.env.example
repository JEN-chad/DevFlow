# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb://localhost:27017/devflow

# Security & Session Token Details
JWT_ACCESS_SECRET=your_jwt_access_secret_key_at_least_32_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_at_least_32_chars
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# GitHub OAuth Setup
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:5000/api/auth/github/callback

# Frontend URL for CORS and Redirects
FRONTEND_URL=http://localhost:5173

# GitHub Webhook Secret (for verifying incoming webhook signatures)
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret_here

